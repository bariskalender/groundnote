# GroundNote environment settings
GROUNDNOTE_ENV=development

# Leave blank to use the app's default local data directory in a future phase.
GROUNDNOTE_DATA_DIR=
GROUNDNOTE_DATABASE_PATH=

# Logging
GROUNDNOTE_LOG_LEVEL=INFO

# Initial local model aliases. These are placeholders until Foundry Local is inspected.
GROUNDNOTE_CHAT_MODEL=phi-3.5-mini
GROUNDNOTE_CHAT_MODEL_FALLBACK=qwen2.5-0.5b
GROUNDNOTE_EMBEDDING_MODEL=qwen3-embedding-0.6b

# Retrieval defaults. These are initial values, not benchmark results.
GROUNDNOTE_TOP_K=4
GROUNDNOTE_SIMILARITY_THRESHOLD=0.35

# Upload and chunking defaults.
GROUNDNOTE_MAX_UPLOAD_MB=50
GROUNDNOTE_CHUNK_TARGET_CHARS=900
GROUNDNOTE_CHUNK_MAX_CHARS=1400
GROUNDNOTE_CHUNK_OVERLAP_CHARS=120
GROUNDNOTE_MIN_CHUNK_CHARS=120
