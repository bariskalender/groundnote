# GroundNote environment settings

# Application
GROUNDNOTE_ENV=development
GROUNDNOTE_DEBUG=false
GROUNDNOTE_LOG_LEVEL=INFO

# Optional local development paths. Leave blank to use platformdirs defaults.
GROUNDNOTE_DATA_DIR=
GROUNDNOTE_DOCUMENT_DIRECTORY=
GROUNDNOTE_DATABASE_DIRECTORY=
GROUNDNOTE_DATABASE_PATH=
GROUNDNOTE_LOG_DIRECTORY=

# Phase 1 benchmark defaults. Re-check aliases if the Foundry Local catalog changes.
GROUNDNOTE_CHAT_MODEL=phi-3.5-mini
GROUNDNOTE_CHAT_MODEL_FALLBACK=qwen2.5-0.5b
GROUNDNOTE_EMBEDDING_MODEL=qwen3-embedding-0.6b
GROUNDNOTE_EMBEDDING_DIMENSION=1024
GROUNDNOTE_EMBEDDING_BATCH_SIZE=16
GROUNDNOTE_EMBEDDING_DTYPE=float32
GROUNDNOTE_EMBEDDING_VERSION=foundry-qwen3-embedding-v1

# Retrieval defaults. These are initial values, not benchmark results.
GROUNDNOTE_TOP_K=5
GROUNDNOTE_RETRIEVAL_CANDIDATE_LIMIT=50
GROUNDNOTE_RETRIEVAL_MINIMUM_SCORE=0.20

# Upload and chunking defaults.
# Keep the default upload value aligned with `.streamlit/config.toml`.
GROUNDNOTE_MAX_UPLOAD_MB=50
GROUNDNOTE_CHUNK_TARGET_CHARS=900
GROUNDNOTE_CHUNK_MAX_CHARS=1400
GROUNDNOTE_CHUNK_OVERLAP_CHARS=120
GROUNDNOTE_MIN_CHUNK_CHARS=120
GROUNDNOTE_CHUNKING_VERSION=hybrid-recursive-v1

# Generation defaults for local models.
GROUNDNOTE_MAXIMUM_OUTPUT_TOKENS=512
GROUNDNOTE_TEMPERATURE=0.2

# Grounded RAG generation defaults.
GROUNDNOTE_RAG_RETRIEVAL_TOP_K=5
GROUNDNOTE_RAG_MINIMUM_SCORE=0.20
GROUNDNOTE_RAG_MAX_CONTEXT_CHARACTERS=6000
GROUNDNOTE_RAG_MAX_CHUNK_COUNT=5
GROUNDNOTE_RAG_TEMPERATURE=0.1
GROUNDNOTE_RAG_MAX_OUTPUT_TOKENS=512
GROUNDNOTE_RAG_PROMPT_VERSION=grounded-rag-v1
GROUNDNOTE_RAG_REQUIRE_CITATIONS=true
GROUNDNOTE_RAG_INSUFFICIENT_EVIDENCE_MODE=explicit
GROUNDNOTE_RAG_MAX_QUERY_CHARACTERS=4000
GROUNDNOTE_KEEP_MODELS_LOADED=true
GROUNDNOTE_FAST_CHAT_MODEL=qwen2.5-0.5b
